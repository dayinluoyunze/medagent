# Environment variables example

# Chat provider: openai / modelscope / minimax
LLM_PROVIDER=modelscope

# Embedding provider: openai / modelscope / none
# If omitted, it follows LLM_PROVIDER when supported, otherwise falls back to none.
EMBEDDING_PROVIDER=modelscope

# Retrieval mode: auto / hybrid / vector / keyword
RETRIEVAL_MODE=auto

# Memory persistence
MEMORY_ENABLED=true

# Logging / safety
LOG_REDACT_QUESTIONS=true
ALLOW_REMOTE_KNOWLEDGE_FETCH=true
ALLOW_URL_KNOWLEDGE_INGESTION=true
URL_KNOWLEDGE_MAX_BYTES=10485760
# REMOTE_KNOWLEDGE_ALLOWLIST=example.com,docs.example.com

# Knowledge stores
MEDICAL_KNOWLEDGE_DIR=knowledge
PERSONAL_KNOWLEDGE_DIR=personal_knowledge
MEDICAL_KNOWLEDGE_ENABLED=true
PERSONAL_KNOWLEDGE_ENABLED=false

# OCR for scanned PDFs and images.
# Requires local Tesseract installation when OCR is actually used.
OCR_ENABLED=true
OCR_LANG=chi_sim+eng
OCR_DPI=200
OCR_MAX_PAGES=20
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSDATA_PREFIX=E:\agent\medagent\.cache\tessdata

# OpenAI API Key
OPENAI_API_KEY=sk-your-key-here

# ModelScope API Key
MODELSCOPE_API_KEY=your-modelscope-key

# MiniMax API Key
MINIMAX_API_KEY=your-minimax-key
